PORT=3000

# Redis (BullMQ)
REDIS_URL=redis://127.0.0.1:6379

# Limite de EANs por requisição em lote
MAX_EANS_PER_REQUEST=1000

# Concorrência dos workers
SEARCH_CONCURRENCY=5
CROP_CONCURRENCY=3

# TTL dos lotes no Redis (em segundos, padrão 24h)
BATCH_TTL_SECONDS=86400

# Diretório de saída dos ZIPs gerados
ZIP_OUTPUT_DIR=./output

# Tamanho máximo da imagem em pixels (0 = sem limite)
MAX_IMAGE_SIZE=800

# URLs customizadas para busca de imagens de produto.
# Use {EAN} como placeholder para o código de barras.
# Separe múltiplas URLs por vírgula.
CUSTOM_SEARCH_URLS=https://www.farma22.com.br/{EAN},https://www.drogariascampea.com.br/{EAN},https://www.drogariaminasbrasil.com.br/catalogsearch/result/?q={EAN},https://www.drogariasminasmais.com.br/{EAN}?_q={EAN}&map=ft

# APIs pagas (fallback - usadas apenas se as URLs customizadas não encontrarem)
SERPER_API_KEY=
SERPAPI_API_KEY=

NAME=iplan_search
TZ=America/Fortaleza
